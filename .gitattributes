# Normalise line endings so the shell launcher stays POSIX-correct.
* text=auto eol=lf

# Windows scripts need CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Shell scripts MUST be LF (a CRLF shebang breaks on macOS/Linux)
*.sh text eol=lf

# Treat images as binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
